#!/bin/bash -e

APP_DIR="$(cd "$(dirname "$0")/.." && pwd)"
REMOTE_URL="${REMOTE_URL:-https://github.com/amitkshitij/rojgar_app.git}"
BRANCH="${DEPLOY_BRANCH:-main}"
SECRET_ENV_FILE="${SECRET_ENV_FILE:-$HOME/.config/rozgar.secret.env}"

cd "$APP_DIR"

if [ ! -d .git ]; then
  git init
  git remote add origin "$REMOTE_URL"
fi

git fetch --prune origin "$BRANCH"

target_revision="$(git rev-parse "origin/$BRANCH")"
current_revision="$(git rev-parse HEAD 2>/dev/null || echo none)"
needs_deploy=0

if [ "$current_revision" != "$target_revision" ]; then
  needs_deploy=1
fi

if [ ! -d node_modules ] || [ ! -f package.json ]; then
  needs_deploy=1
fi

if [ ! -f .output/server/index.mjs ]; then
  needs_deploy=1
fi

if [ "$needs_deploy" -eq 0 ]; then
  echo "Already on $BRANCH at $current_revision"
  exit 0
fi

echo "Deploying $BRANCH at $target_revision"

git checkout -f "$BRANCH" 2>/dev/null || git checkout -b "$BRANCH"
git reset --hard "$target_revision"

if [ -f .env ]; then
  chmod 600 .env
fi

if [ -f "$SECRET_ENV_FILE" ]; then
  chmod 600 "$SECRET_ENV_FILE"
fi

if [ -f package-lock.json ]; then
  npm ci --no-audit --no-fund
else
  npm install --no-audit --no-fund
fi

npm run build

./bin/release
